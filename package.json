{
  "name": "draco-sports-manager",
  "version": "1.0.0",
  "description": "Draco Sports Manager - Node.js Migration",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "prepare": "husky",
    "worktree:cleanup": "bash worktree-cleanup.sh",
    "worktree:ports": "cat draco-nodejs/.worktree-ports.json | jq .",
    "worktree:status": "bash worktree-status.sh",
    "stop": "bash scripts/stop-processes.sh",
    "stop:backend": "bash scripts/stop-backend.sh",
    "stop:frontend": "bash scripts/stop-frontend.sh",
    "load-test": "node scripts/load-test-driver.js",
    "load-test:dry-run": "node scripts/load-test-driver.js --dry-run",
    "machine:ip": "node -e \"const os=require('os'); const interfaces=os.networkInterfaces(); const ips=Object.values(interfaces).flatMap(list=>list||[]).filter(iface=>iface&&iface.family==='IPv4'&&!iface.internal).map(iface=>iface.address); if(!ips.length){console.error('No IPv4 address found'); process.exit(1);} console.log(ips[0]);\"",
    "backend:start": "pnpm --filter @draco/backend start",
    "backend:build": "pnpm --filter @draco/backend build",
    "backend:dev": "pnpm --filter @draco/backend dev",
    "backend:test": "pnpm --filter @draco/backend test",
    "backend:install": "pnpm --filter @draco/backend install",
    "backend:prisma-generate": "pnpm --filter @draco/backend exec prisma generate",
    "backend:lint": "pnpm --filter @draco/backend lint",
    "backend:lint:fix": "pnpm --filter @draco/backend lint:fix",
    "backend:format": "pnpm --filter @draco/backend format",
    "backend:type-check": "pnpm --filter @draco/backend type-check",
    "backend:clean": "pnpm --filter @draco/backend clean",
    "backend:docs:generate": "pnpm --filter @draco/backend docs:generate",
    "frontend:start": "pnpm --filter @draco/frontend-next start",
    "frontend:build": "pnpm --filter @draco/frontend-next build",
    "frontend:test": "pnpm --filter @draco/frontend-next test",
    "frontend:install": "pnpm --filter @draco/frontend-next install",
    "frontend:lint": "pnpm --filter @draco/frontend-next lint",
    "frontend:lint:fix": "pnpm --filter @draco/frontend-next lint:fix",
    "frontend:format": "pnpm --filter @draco/frontend-next format",
    "frontend:type-check": "pnpm --filter @draco/frontend-next type-check",
    "frontend:e2e": "pnpm --filter @draco/frontend-next e2e",
    "frontend:e2e:ui": "pnpm --filter @draco/frontend-next e2e:ui",
    "frontend:e2e:last-failed": "pnpm --filter @draco/frontend-next e2e:last-failed",
    "frontend:e2e:reap": "pnpm --filter @draco/frontend-next e2e:reap",
    "dev": "concurrently \"pnpm --filter @draco/backend dev\" \"pnpm --filter @draco/frontend-next dev\"",
    "dev:debug": "concurrently \"pnpm --filter @draco/backend dev:debug\" \"pnpm --filter @draco/frontend-next dev\"",
    "build": "pnpm --filter @draco/shared-schemas build && pnpm run sync:api && pnpm --filter @draco/backend build && pnpm --filter @draco/frontend-next build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "pnpm -r run format",
    "type-check": "pnpm -r run type-check",
    "test": "pnpm -r run test",
    "start": "concurrently \"pnpm --filter @draco/backend start\" \"pnpm --filter @draco/frontend-next start\"",
    "secrets:update-baseline": "node scripts/update-baseline.js",
    "sync:api": "pnpm --filter @draco/backend generate:openapi && pnpm --filter @draco/backend generate:client",
    "mobile:start": "pnpm --filter @draco/mobile start",
    "mobile:lint": "pnpm --filter @draco/mobile lint",
    "mobile:test": "pnpm --filter @draco/mobile test",
    "mobile:type-check": "pnpm --filter @draco/mobile type-check",
    "mobile:format": "pnpm --filter @draco/mobile format",
    "docker:dev": "concurrently \"docker compose --profile docker-dev up --build backend-docker\" \"pnpm --filter @draco/frontend-next dev\"",
    "docker:backend:build": "docker build -f draco-nodejs/backend/Dockerfile -t draco-backend .",
    "docker:backend:test": "docker compose --profile test up --build backend-test"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^24.0.1",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "baseline-browser-mapping": "^2.10.11",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "draco-nodejs/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
