{
  "name": "@draco/frontend-next",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c 'HOST_VALUE=\"${HOST:-0.0.0.0}\"; if command -v mkcert >/dev/null 2>&1; then export NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\"; else unset NODE_EXTRA_CA_CERTS; fi; next dev --hostname \"$HOST_VALUE\"'",
    "build": "eslint . && next build",
    "start": "dotenv -e .env.local -- sh -c 'HOST_VALUE=\"${HOST:-0.0.0.0}\"; if command -v mkcert >/dev/null 2>&1; then export NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\"; else unset NODE_EXTRA_CA_CERTS; fi; next start --hostname \"$HOST_VALUE\"'",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "e2e": "dotenv -e .env.local -e .env.e2e -- playwright test",
    "e2e:ui": "dotenv -e .env.local -e .env.e2e -- playwright test --ui",
    "e2e:headed": "dotenv -e .env.local -e .env.e2e -- playwright test --headed",
    "e2e:chromium": "dotenv -e .env.local -e .env.e2e -- playwright test --project=chromium",
    "e2e:debug": "dotenv -e .env.local -e .env.e2e -- playwright test --debug",
    "e2e:report": "playwright show-report e2e/.report",
    "e2e:codegen": "dotenv -e .env.local -e .env.e2e -- playwright codegen http://localhost:4001",
    "e2e:update-snapshots": "dotenv -e .env.local -e .env.e2e -- playwright test --update-snapshots --project=chromium",
    "e2e:last-failed": "dotenv -e .env.local -e .env.e2e -- playwright test --last-failed --retries=1",
    "e2e:reap": "dotenv -e ../backend/.env -e .env.e2e -- tsx e2e/scripts/reap-e2e-data.ts"
  },
  "dependencies": {
    "@draco/shared-api-client": "workspace:*",
    "@draco/shared-schemas": "workspace:*",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@lexical/code": "^0.42.0",
    "@lexical/html": "^0.42.0",
    "@lexical/link": "^0.42.0",
    "@lexical/list": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@lexical/selection": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@mui/utils": "^7.3.9",
    "@mui/x-data-grid": "8.28.1",
    "@mui/x-date-pickers": "^8.27.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "file-type": "^21.3.4",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lexical": "^0.42.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.554.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^14.4.1",
    "react-hook-form": "^7.72.0",
    "react-leaflet": "^5.0.0",
    "react-transition-group": "^4.4.5",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "validator": "^13.15.26",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/pg": "^8.11.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.4.0",
    "pg": "^8.20.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0"
  }
}
