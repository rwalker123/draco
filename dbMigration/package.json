{
  "name": "draco-file-migration",
  "version": "1.0.0",
  "description": "File migration utilities for Draco Sports Manager",
  "type": "module",
  "main": "migrate-files.js",
  "scripts": {
    "migrate-files": "tsx migrate-files.ts",
    "migrate-files:check": "./migrate-files.sh --check-only",
    "migrate-files:dry-run": "./migrate-files.sh --dry-run",
    "lint": "prettier --check \"**/*.{ts,js}\" --config ../.prettierrc --ignore-path ../.prettierignore",
    "lint:fix": "prettier --write \"**/*.{ts,js}\" --config ../.prettierrc --ignore-path ../.prettierignore",
    "test": "echo \"No tests for dbMigration\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "basic-ftp": "^5.2.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Draco Migration Team",
  "license": "MIT"
}
